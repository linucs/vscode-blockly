// A launch configuration that compiles the extension and then opens it inside a new window
// Use IntelliSense to learn about possible attributes.
// Hover to view descriptions of existing attributes.
// For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Run Extension",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}"
			],
			"outFiles": [
				"${workspaceFolder}/dist/**/*.js"
			],
			"preLaunchTask": "${defaultBuildTask}"
		},
		{
			// Loads BOTH this extension and the sibling vscode-arduino-cli from
			// source into one Extension Development Host, so the optional toolchain
			// integration (arduino-cli's editor/title compile/upload buttons over
			// the Maker Block Studio) can be exercised and debugged end-to-end.
			// Do NOT also have vscode-arduino-cli installed as a VSIX while using
			// this (the same extension id loaded twice conflicts).
			"name": "Run Extension + Arduino Sketch Studio",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}",
				"--extensionDevelopmentPath=/Users/linucs/Projects/vscode-arduino-cli"
			],
			"outFiles": [
				"${workspaceFolder}/dist/**/*.js",
				"/Users/linucs/Projects/vscode-arduino-cli/dist/**/*.js"
			],
			"preLaunchTask": "watch + arduino-cli"
		}
	]
}
