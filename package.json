{
  "name": "blocks-editor",
  "displayName": "Blocks Editor",
  "description": "Visual block programming for PlatformIO and Arduino CLI using Blockly",
  "version": "0.0.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/linucs/blocks-editor"
  },
  "keywords": [
    "arduino",
    "blockly",
    "platformio",
    "visual-programming",
    "education"
  ],
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Programming Languages",
    "Education"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "blocks-editor.refreshCatalogs",
        "title": "Blocks Editor: Refresh Remote Catalogs"
      }
    ],
    "customEditors": [
      {
        "viewType": "blocks-editor.editor",
        "displayName": "Blocks Editor Editor",
        "selector": [
          {
            "filenamePattern": "*.cpp"
          },
          {
            "filenamePattern": "*.cc"
          },
          {
            "filenamePattern": "*.cxx"
          },
          {
            "filenamePattern": "*.c"
          },
          {
            "filenamePattern": "*.ino"
          },
          {
            "filenamePattern": "*.pde"
          }
        ],
        "priority": "option"
      }
    ],
    "configuration": {
      "title": "Blocks Editor",
      "properties": {
        "blocks-editor.generateOnChange": {
          "type": "boolean",
          "default": true,
          "description": "Generate code automatically whenever blocks change. When disabled, code is generated only when the Generate C++ button is pressed."
        },
        "blocks-editor.showMinimap": {
          "type": "boolean",
          "default": false,
          "description": "Show a minimap overview of the block workspace in the bottom-right corner."
        },
        "blocks-editor.categoryColors": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "pattern": "^#[0-9A-Fa-f]{6}$"
          },
          "default": {},
          "markdownDescription": "Map toolbox category labels to hex colours. The label is matched against the `category` field in block catalog YAML files.\n\nBuilt-in categories (Logic, Loops, Math, Text, Variables, Arrays, Functions) fall back to the default palette if not overridden. Catalog-defined categories fall back to a neutral default.\n\nExample:\n```json\n{\n  \"Logic\": \"#29B6F6\",\n  \"Sensors\": \"#26A69A\"\n}\n```"
        },
        "blocks-editor.catalogPaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Local directories or remote URLs for block catalog YAML files. Local paths (relative to the workspace root, or absolute) are scanned recursively. URLs (http/https) are downloaded to the project .blocks/ folder on first load; use the \"Refresh Remote Catalogs\" command to force re-download."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "yarn run package",
    "compile": "yarn run check-types && yarn run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "yarn run check-types && yarn run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "yarn run compile-tests && yarn run compile && yarn run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@blockly/block-dynamic-connection": "^0.8.9",
    "@blockly/field-angle": "^6.0.9",
    "@blockly/field-bitmap": "^6.0.9",
    "@blockly/field-colour": "^6.0.12",
    "@blockly/field-colour-hsv-sliders": "^6.0.12",
    "@blockly/field-dependent-dropdown": "^5.0.10",
    "@blockly/field-grid-dropdown": "^6.0.10",
    "@blockly/field-multilineinput": "^6.0.9",
    "@blockly/field-slider": "^8.0.9",
    "@blockly/plugin-scroll-options": "^7.0.9",
    "@blockly/plugin-typed-variable-modal": "^9.0.9",
    "@blockly/shadow-block-converter": "^7.0.10",
    "@blockly/toolbox-search": "^3.1.9",
    "@blockly/workspace-backpack": "^7.0.11",
    "@blockly/workspace-minimap": "^0.3.9",
    "@mit-app-inventor/blockly-plugin-workspace-multiselect": "^1.0.2",
    "@vscode/webview-ui-toolkit": "^1.4.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "blockly": "^12.5.1",
    "js-yaml": "^4.1.1"
  }
}
