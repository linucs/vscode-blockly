{
  "name": "blocks-editor",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.3.2",
  "license": "MIT",
  "publisher": "linucs",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#1E1E2E",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/linucs/vscode-blockly"
  },
  "bugs": {
    "url": "https://github.com/linucs/vscode-blockly/issues"
  },
  "homepage": "https://github.com/linucs/vscode-blockly#readme",
  "keywords": [
    "arduino",
    "blockly",
    "platformio",
    "arduino-cli",
    "visual-programming",
    "block-programming",
    "no-code",
    "scratch",
    "embedded",
    "microcontroller",
    "esp32",
    "stem",
    "education"
  ],
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Programming Languages",
    "Education"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "walkthroughs": [
      {
        "id": "blocks-editor.welcome",
        "title": "%walkthrough.title%",
        "description": "%walkthrough.description%",
        "steps": [
          {
            "id": "openWithBlocks",
            "title": "%walkthrough.openWithBlocks.title%",
            "description": "%walkthrough.openWithBlocks.description%",
            "media": {
              "svg": "images/walkthrough/open-with-blocks.svg"
            },
            "completionEvents": [
              "onView:blocks-editor.editor"
            ]
          },
          {
            "id": "arduinoCli",
            "title": "%walkthrough.arduinoCli.title%",
            "description": "%walkthrough.arduinoCli.description%",
            "media": {
              "svg": "images/walkthrough/compile-upload.svg"
            },
            "completionEvents": [
              "onExtensionInstalled:linucs.vscode-arduino-cli-ide"
            ]
          },
          {
            "id": "authorBlocks",
            "title": "%walkthrough.authorBlocks.title%",
            "description": "%walkthrough.authorBlocks.description%",
            "media": {
              "svg": "images/walkthrough/author-blocks.svg"
            },
            "completionEvents": [
              "onCommand:blocks-editor.enableClaudeCodeIntegration"
            ]
          },
          {
            "id": "communityCatalog",
            "title": "%walkthrough.communityCatalog.title%",
            "description": "%walkthrough.communityCatalog.description%",
            "media": {
              "svg": "images/walkthrough/community-catalog.svg"
            },
            "completionEvents": [
              "onView:blocks-editor.catalogRegistry"
            ]
          },
          {
            "id": "contribute",
            "title": "%walkthrough.contribute.title%",
            "description": "%walkthrough.contribute.description%",
            "media": {
              "svg": "images/walkthrough/contribute.svg"
            },
            "completionEvents": [
              "onLink:https://github.com/linucs/vscode-blockly"
            ]
          }
        ]
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "blocks-catalog-browser",
          "title": "%viewContainer.catalogBrowser.title%",
          "icon": "images/icon.svg"
        }
      ]
    },
    "views": {
      "blocks-catalog-browser": [
        {
          "id": "blocks-editor.catalogRegistry",
          "name": "%view.catalogRegistry.name%"
        }
      ]
    },
    "menus": {
      "explorer/context": [
        {
          "command": "blocks-editor.openInBlocksEditor",
          "when": "resourceExtname == .ino || resourceExtname == .pde || resourceExtname == .cpp || resourceExtname == .py",
          "group": "navigation@10"
        },
        {
          "command": "blocks-editor.contributeCatalog",
          "when": "resourceExtname =~ /\\.ya?ml$/ && resourcePath =~ /[\\\\/]\\.blocks[\\\\/]/",
          "group": "navigation@11"
        }
      ],
      "editor/title/context": [
        {
          "command": "blocks-editor.openInBlocksEditor",
          "when": "resourceExtname == .ino || resourceExtname == .pde || resourceExtname == .cpp || resourceExtname == .py",
          "group": "1_open@10"
        }
      ],
      "view/title": [
        {
          "command": "blocks-editor.searchRegistry",
          "when": "view == blocks-editor.catalogRegistry",
          "group": "navigation@1"
        },
        {
          "command": "blocks-editor.refreshRegistry",
          "when": "view == blocks-editor.catalogRegistry",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "blocks-editor.downloadCatalog",
          "when": "view == blocks-editor.catalogRegistry && viewItem == catalogEntry",
          "group": "inline"
        }
      ]
    },
    "mcpServerDefinitionProviders": [
      {
        "id": "blocks-editor",
        "label": "%mcp.blocksEditor.label%"
      }
    ],
    "commands": [
      {
        "command": "blocks-editor.openInBlocksEditor",
        "title": "%command.openInBlocksEditor%",
        "icon": "$(symbol-structure)"
      },
      {
        "command": "blocks-editor.refreshCatalogs",
        "title": "%command.refreshCatalogs%"
      },
      {
        "command": "blocks-editor.enableClaudeCodeIntegration",
        "title": "%command.enableClaudeCode%"
      },
      {
        "command": "blocks-editor.refreshRegistry",
        "title": "%command.refreshRegistry%",
        "icon": "$(refresh)"
      },
      {
        "command": "blocks-editor.downloadCatalog",
        "title": "%command.downloadCatalog%",
        "icon": "$(cloud-download)"
      },
      {
        "command": "blocks-editor.searchRegistry",
        "title": "%command.searchRegistry%",
        "icon": "$(search)"
      },
      {
        "command": "blocks-editor.contributeCatalog",
        "title": "%command.contributeCatalog%",
        "icon": "$(cloud-upload)"
      }
    ],
    "customEditors": [
      {
        "viewType": "blocks-editor.editor",
        "displayName": "%editor.displayName%",
        "selector": [
          {
            "filenamePattern": "*.ino"
          },
          {
            "filenamePattern": "*.pde"
          },
          {
            "filenamePattern": "*.cpp"
          },
          {
            "filenamePattern": "*.py"
          }
        ],
        "priority": "option"
      }
    ],
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "blocks-editor.generateOnChange": {
          "type": "boolean",
          "default": true,
          "description": "%config.generateOnChange%"
        },
        "blocks-editor.showMinimap": {
          "type": "boolean",
          "default": false,
          "description": "%config.showMinimap%"
        },
        "blocks-editor.annotateGeneratedCode": {
          "type": "boolean",
          "default": true,
          "description": "%config.annotateGeneratedCode%"
        },
        "blocks-editor.catalogPaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "%config.catalogPaths%"
        },
        "blocks-editor.catalogRegistryUrl": {
          "type": "string",
          "default": "https://raw.githubusercontent.com/linucs/blocks-community-catalog/main/index.json",
          "description": "%config.catalogRegistryUrl%"
        },
        "blocks-editor.contributionRepo": {
          "type": "string",
          "default": "linucs/blocks-community-catalog",
          "description": "%config.contributionRepo%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "yarn run package",
    "compile": "yarn run check-editor-ext && yarn run check-types && yarn run lint && yarn run check-l10n && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "yarn run check-types && yarn run lint && yarn run check-l10n && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "yarn run compile-tests && yarn run compile && yarn run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "check-l10n": "node scripts/check-l10n.js",
    "check-editor-ext": "node scripts/check-editor-extensions.js",
    "test": "vscode-test",
    "vsix": "vsce package --no-dependencies",
    "publish:vsce": "vsce publish --no-dependencies",
    "publish:ovsx": "ovsx publish --no-dependencies"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "ovsx": "^0.10.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@blockly/block-dynamic-connection": "^0.8.9",
    "@blockly/field-angle": "^6.0.9",
    "@blockly/field-bitmap": "^6.0.9",
    "@blockly/field-colour": "^6.0.12",
    "@blockly/field-colour-hsv-sliders": "^6.0.12",
    "@blockly/field-dependent-dropdown": "^5.0.10",
    "@blockly/field-grid-dropdown": "^6.0.10",
    "@blockly/field-multilineinput": "^6.0.9",
    "@blockly/field-slider": "^8.0.9",
    "@blockly/plugin-scroll-options": "^7.0.9",
    "@blockly/plugin-typed-variable-modal": "^9.0.9",
    "@blockly/shadow-block-converter": "^7.0.10",
    "@blockly/toolbox-search": "^3.1.9",
    "@blockly/workspace-backpack": "^7.0.11",
    "@blockly/workspace-minimap": "^0.3.9",
    "@mit-app-inventor/blockly-plugin-workspace-multiselect": "^1.0.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vscode/l10n": "^0.0.18",
    "@vscode/webview-ui-toolkit": "^1.4.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "blockly": "^12.5.1",
    "js-yaml": "^4.1.1",
    "zod": "^4.4.3"
  }
}
