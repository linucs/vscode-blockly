{
  "name": "blocks-editor",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.0.1",
  "license": "MIT",
  "publisher": "linucs",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#1E1E2E",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/linucs/vscode-blockly"
  },
  "bugs": {
    "url": "https://github.com/linucs/vscode-blockly/issues"
  },
  "homepage": "https://github.com/linucs/vscode-blockly#readme",
  "keywords": [
    "arduino",
    "blockly",
    "platformio",
    "arduino-cli",
    "visual-programming",
    "block-programming",
    "no-code",
    "scratch",
    "embedded",
    "microcontroller",
    "esp32",
    "stem",
    "education"
  ],
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Programming Languages",
    "Education"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "chatParticipants": [
      {
        "id": "blocks-editor.blockAuthor",
        "fullName": "%chat.blockAuthor.fullName%",
        "name": "blocks",
        "description": "%chat.blockAuthor.description%",
        "isSticky": true,
        "commands": [
          {
            "name": "research",
            "description": "%chat.command.research%"
          },
          {
            "name": "design",
            "description": "%chat.command.design%"
          },
          {
            "name": "generate",
            "description": "%chat.command.generate%"
          },
          {
            "name": "validate",
            "description": "%chat.command.validate%"
          }
        ]
      }
    ],
    "languageModelTools": [
      {
        "name": "blocks-editor-fetch-url",
        "displayName": "%tool.fetchUrl.displayName%",
        "modelDescription": "%tool.fetchUrl.description%",
        "inputSchema": {
          "type": "object",
          "properties": {
            "url": {
              "type": "string",
              "description": "The URL to fetch"
            }
          },
          "required": [
            "url"
          ]
        }
      },
      {
        "name": "blocks-editor-search-pio-registry",
        "displayName": "%tool.searchPio.displayName%",
        "modelDescription": "%tool.searchPio.description%",
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Library name or keyword to search"
            }
          },
          "required": [
            "query"
          ]
        }
      },
      {
        "name": "blocks-editor-check-arduino-registry",
        "displayName": "%tool.checkArduino.displayName%",
        "modelDescription": "%tool.checkArduino.description%",
        "inputSchema": {
          "type": "object",
          "properties": {
            "libraryName": {
              "type": "string",
              "description": "Library name to look up"
            }
          },
          "required": [
            "libraryName"
          ]
        }
      },
      {
        "name": "blocks-editor-validate-catalog",
        "displayName": "%tool.validateCatalog.displayName%",
        "modelDescription": "%tool.validateCatalog.description%",
        "inputSchema": {
          "type": "object",
          "properties": {
            "yaml": {
              "type": "string",
              "description": "The YAML catalog content to validate"
            }
          },
          "required": [
            "yaml"
          ]
        }
      },
      {
        "name": "blocks-editor-save-catalog",
        "displayName": "%tool.saveCatalog.displayName%",
        "userDescription": "%tool.saveCatalog.userDescription%",
        "modelDescription": "%tool.saveCatalog.description%",
        "inputSchema": {
          "type": "object",
          "properties": {
            "filename": {
              "type": "string",
              "description": "Filename (e.g. wifinina.yaml)"
            },
            "content": {
              "type": "string",
              "description": "The YAML content to save"
            }
          },
          "required": [
            "filename",
            "content"
          ]
        }
      }
    ],
    "commands": [
      {
        "command": "blocks-editor.refreshCatalogs",
        "title": "%command.refreshCatalogs%"
      },
      {
        "command": "blocks-editor.enableClaudeCodeIntegration",
        "title": "%command.enableClaudeCode%"
      }
    ],
    "customEditors": [
      {
        "viewType": "blocks-editor.editor",
        "displayName": "%editor.displayName%",
        "selector": [
          {
            "filenamePattern": "*.cpp"
          },
          {
            "filenamePattern": "*.cc"
          },
          {
            "filenamePattern": "*.cxx"
          },
          {
            "filenamePattern": "*.c"
          },
          {
            "filenamePattern": "*.ino"
          },
          {
            "filenamePattern": "*.pde"
          }
        ],
        "priority": "option"
      }
    ],
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "blocks-editor.generateOnChange": {
          "type": "boolean",
          "default": true,
          "description": "%config.generateOnChange%"
        },
        "blocks-editor.showMinimap": {
          "type": "boolean",
          "default": false,
          "description": "%config.showMinimap%"
        },
        "blocks-editor.catalogPaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "%config.catalogPaths%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "yarn run package",
    "compile": "yarn run check-types && yarn run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "yarn run check-types && yarn run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "yarn run compile-tests && yarn run compile && yarn run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "vsix": "vsce package --no-dependencies",
    "publish:vsce": "vsce publish --no-dependencies",
    "publish:ovsx": "ovsx publish --no-dependencies"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "ovsx": "^0.10.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "@vscode/vsce": "^3.9.1"
  },
  "dependencies": {
    "@blockly/block-dynamic-connection": "^0.8.9",
    "@blockly/field-angle": "^6.0.9",
    "@blockly/field-bitmap": "^6.0.9",
    "@blockly/field-colour": "^6.0.12",
    "@blockly/field-colour-hsv-sliders": "^6.0.12",
    "@blockly/field-dependent-dropdown": "^5.0.10",
    "@blockly/field-grid-dropdown": "^6.0.10",
    "@blockly/field-multilineinput": "^6.0.9",
    "@blockly/field-slider": "^8.0.9",
    "@blockly/plugin-scroll-options": "^7.0.9",
    "@blockly/plugin-typed-variable-modal": "^9.0.9",
    "@blockly/shadow-block-converter": "^7.0.10",
    "@blockly/toolbox-search": "^3.1.9",
    "@blockly/workspace-backpack": "^7.0.11",
    "@blockly/workspace-minimap": "^0.3.9",
    "@mit-app-inventor/blockly-plugin-workspace-multiselect": "^1.0.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vscode/l10n": "^0.0.18",
    "@vscode/webview-ui-toolkit": "^1.4.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "blockly": "^12.5.1",
    "js-yaml": "^4.1.1",
    "zod": "^4.4.3"
  }
}
